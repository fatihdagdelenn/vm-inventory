# ==========================================================
# VM Envanter Yönetim Sistemi - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri düzenleyin
# ==========================================================

# Uygulama
APP_NAME="VM Envanter Yönetim Sistemi"
DEBUG=false
SECRET_KEY=degistir-bunu-cok-gizli-bir-anahtar-ile
# Kimlik bilgilerini şifrelemek için Fernet anahtarı.
# Üretmek için: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=530TqGx4IL5zapc2lSIDgV1dVsxZ6UZGoACQiYomCG0=

# Veritabanı (PostgreSQL önerilir; küçük kurulumlar için SQLite)
# PostgreSQL: postgresql+psycopg2://kullanici:parola@db:5432/vminventory
# SQLite:     sqlite:///./data/vminventory.db
DATABASE_URL=postgresql+psycopg2://vminv:vminv_parola@db:5432/vminventory

# Oturum
SESSION_TIMEOUT_MINUTES=30

# Senkronizasyon (dakika cinsinden) - kullanıcı aramaları canlı API'ye gitmez,
# veriler bu aralıklarla arka planda toplanıp lokal veritabanında saklanır.
SYNC_INTERVAL_MINUTES=15

# LDAP / Active Directory (opsiyonel)
LDAP_ENABLED=false
LDAP_SERVER=ldap://dc01.sirket.local
LDAP_BASE_DN=DC=sirket,DC=local
LDAP_USER_DN_TEMPLATE={username}@sirket.local
LDAP_DEFAULT_ROLE=viewer

# Anlık kullanım (CPU/RAM/disk) tazeleme aralığı, dakika.
# Tam senkronizasyondan bağımsız, çok hafif bir API çağrısıyla çalışır.
USAGE_SYNC_INTERVAL_MINUTES=3
